# OAuth2 credentials for the seven.io Zapier integration.
# In Zapier these are stored as environment variables on the integration version
# (set via `zapier-platform env:set <version> KEY=VALUE`). A local copy is used
# by `zapier-platform test` / `zapier-platform invoke` to resolve `process.env.*`
# template placeholders in authentication.js.
CLIENT_ID=
CLIENT_SECRET=

# Tokens of an already-authorized test account. Obtain them once by completing
# the OAuth flow against https://oauth.seven.io — then paste the values here so
# local invocations can act as that user without re-authorizing each time.
ACCESS_TOKEN=
REFRESH_TOKEN=
